# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# typescript
*.tsbuildinfo
next-env.d.ts

.ignore/
.vscode/
dev_scripts/

# pipeline — raw downloads and intermediate files (large, regenerable)
pipeline/data/raw/*
pipeline/data/processed/*
!pipeline/data/raw/.gitkeep
!pipeline/data/processed/.gitkeep

# pipeline — generated geo output (regenerable from pipeline)
public/geo/*.pmtiles
!public/geo/.gitkeep

# python
__pycache__/
*.py[cod]
.venv/
*.egg-info/